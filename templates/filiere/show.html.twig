{% extends 'admin/base.html.twig' %}
{% block title %}Détail — {{ filiere.nom }}{% endblock %}

{% block body %}
<div class="page-heading">
    <div class="page-title-headings">
        <h3>Détail de la Filière</h3>
        <div>
            <a href="{{ path('app_filiere_edit', {'id': filiere.id}) }}" class="btn btn-warning btn-sm me-1">
                <i class="bi bi-pencil me-1"></i> Modifier
            </a>
            <a href="{{ path('app_filiere_index') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i> Retour
            </a>
        </div>
    </div>
</div>

<section class="section">
    <div class="card">
        <div class="card-header">
            <h4 class="card-title"><i class="bi bi-journal-bookmark-fill text-primary me-2"></i>{{ filiere.nom }}</h4>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tbody>
                    <tr><th width="220">ID</th><td><span class="badge bg-light-primary text-primary">{{ filiere.id }}</span></td></tr>
                    <tr><th>Nom</th><td><strong>{{ filiere.nom }}</strong></td></tr>
                    <tr><th>Description</th><td>{{ filiere.description }}</td></tr>
                    <tr><th>Conditions d'admission</th><td>{{ filiere.conditionsAdmission }}</td></tr>
                    <tr><th>Débouchés</th><td>{{ filiere.debouches }}</td></tr>
                    <tr><th>Niveau</th><td>{{ filiere.niveau }}</td></tr>
                    <tr><th>Domaine</th><td>{{ filiere.domaine }}</td></tr>
                </tbody>
            </table>
            <div class="mt-3">
                {{ include('filiere/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</section>
{% endblock %}
