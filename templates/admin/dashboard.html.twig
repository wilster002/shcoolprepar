{% extends 'admin/base.html.twig' %}
{% block title %}Dashboard - SchoolPrepar{% endblock %}

{% block body %}
<div class="page-heading">
    <h3>Dashboard</h3>
</div>

<section class="row">

    {# ===== STATS CARDS ===== #}
    <div class="col-6 col-lg-3 col-md-6">
        <div class="card">
            <div class="card-body px-4 py-4-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted font-semibold">Filières</h6>
                        {%for filiere in filieres%}
                        <h4 class="font-extrabold mb-0">{{filieres|length}}</h4>
                        {%endfor%}
                    </div>
                    <div class="stats-icon blue">
                        <i class="bi bi-journal-bookmark-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3 col-md-6">
        <div class="card">
            <div class="card-body px-4 py-4-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                    {%for etablissement in etablissements%}
                        <h6 class="text-muted font-semibold">Établissements</h6>
                        <h4 class="font-extrabold mb-0">{{etablissements|length}}</h4>
                    {%endfor%}
                    </div>
                    <div class="stats-icon green">
                        <i class="bi bi-building"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3 col-md-6">
        <div class="card">
            <div class="card-body px-4 py-4-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted font-semibold">Utilisateurs</h6>
                        <h4 class="font-extrabold mb-0">0</h4>
                    </div>
                    <div class="stats-icon purple">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-3 col-md-6">
        <div class="card">
            <div class="card-body px-4 py-4-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted font-semibold">Visites</h6>
                        <h4 class="font-extrabold mb-0">500+</h4>
                    </div>
                    <div class="stats-icon red">
                        <i class="bi bi-eye-fill"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ===== ACCÈS RAPIDE ===== #}
    <div class="col-12 col-lg-8">
        <div class="card">
            <div class="card-header">
                <h4>Filières récentes</h4>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nom</th>
                            <th>Description</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                     {%for filiere in filieres%}
                        <tr>
                            <td>{{filiere.id}}<td>
                            <td><strong>{{filiere.nom}}</strong></td>
                            <td>{{filiere.description}}</td>
                            <td><a href="{{ path('app_filiere_index') }}" class="badge bg-primary">Voir</a></td>
                        </tr>
                     {%endfor%}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card">
            <div class="card-header">
                <h4>Accès rapide</h4>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('app_filiere_index') }}" class="btn btn-primary">
                        <i class="bi bi-journal-bookmark-fill me-2"></i>Gérer les Filières
                    </a>
                    <a href="{{ path('app_etablissement_index') }}" class="btn btn-outline-primary">
                        <i class="bi bi-building me-2"></i>Gérer les Établissements
                    </a>
                    <a href="https://github.com/wilster002/shcoolprepar/tree/master" target="_blank" class="btn btn-outline-secondary">
                        <i class="bi bi-github me-2"></i>Dépôt GitHub
                    </a>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h4>Infos</h4></div>
            <div class="card-body">
                <p class="mb-1"><i class="bi bi-calendar3 text-primary me-2"></i>{{ "now"|date("d/m/Y") }}</p>
                <p class="mb-0"><i class="bi bi-code-slash text-success me-2"></i>Symfony — IT232</p>
            </div>
        </div>
    </div>

</section>
{% endblock %}
