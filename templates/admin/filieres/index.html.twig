{% extends 'admin/base.html.twig' %}
{% block title %}Gestion des Filières{% endblock %}

{% block body %}
<div class="page-heading">
    <div class="page-title-headings">
        <h3>Gestion des Filières</h3>
        <a href="#" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i> Ajouter une Filière
        </a>
    </div>
</div>

<section class="section">
    <div class="card">
        <div class="card-header">
            <h4 class="card-title"><i class="bi bi-journal-bookmark-fill text-primary me-2"></i>Liste des Filières</h4>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="badge bg-light-primary text-primary">1</span></td>
                        <td><strong>Informatique</strong></td>
                        <td class="text-muted">Développement, réseau et cybersécurité</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i> Modifier</a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Supprimer</a>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="badge bg-light-primary text-primary">2</span></td>
                        <td><strong>Gestion</strong></td>
                        <td class="text-muted">Comptabilité, finance et management</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i> Modifier</a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Supprimer</a>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="badge bg-light-primary text-primary">3</span></td>
                        <td><strong>Marketing</strong></td>
                        <td class="text-muted">Publicité, communication et stratégie digitale</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i> Modifier</a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Supprimer</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
{% endblock %}
