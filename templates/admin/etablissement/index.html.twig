{% extends 'admin/base.html.twig' %}
{% block title %}Gestion des Établissements{% endblock %}

{% block body %}
<div class="page-heading">
    <div class="page-title-headings">
        <h3>Gestion des Établissements</h3>
        <a href="#" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i> Ajouter un Établissement
        </a>
    </div>
</div>

<section class="section">
    <div class="card">
        <div class="card-header">
            <h4 class="card-title"><i class="bi bi-building text-success me-2"></i>Liste des Établissements</h4>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="badge bg-light-success text-success">1</span></td>
                        <td><strong>Lycée Moderne</strong></td>
                        <td class="text-muted">Enseignement secondaire complet</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i> Modifier</a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Supprimer</a>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="badge bg-light-success text-success">2</span></td>
                        <td><strong>Université de Lomé</strong></td>
                        <td class="text-muted">Formation supérieure et recherche</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i> Modifier</a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Supprimer</a>
                        </td>
                    </tr>
                    <tr>
                        <td><span class="badge bg-light-success text-success">3</span></td>
                        <td><strong>Institut Supérieur de Technologie</strong></td>
                        <td class="text-muted">Technologies et métiers spécialisés</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i> Modifier</a>
                            <a href="#" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Supprimer</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
{% endblock %}
