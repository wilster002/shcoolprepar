{% extends 'front/base.html.twig' %}

{% block title %}Établissements - SchoolPrepar{% endblock %}

{% block body %}
<h2 class="fw-bold mb-4" style="color:#1a3c5e; border-left: 4px solid #2980b9; padding-left: 12px;">
    Liste des Établissements
</h2>

<div class="card-list">
    {% for etablissement in etablissements %}
    <div class="card mb-3">
        <div class="card-body">
            <h3 class="card-title">{{ etablissement.nom }}</h3>
            <p><i class="bi bi-geo-alt-fill text-primary me-1"></i> <strong>Localisation :</strong> {{ etablissement.localisation }}</p>
            <p><i class="bi bi-telephone-fill text-success me-1"></i> <strong>Contact :</strong> {{ etablissement.contact }}</p>
            <p><i class="bi bi-building text-warning me-1"></i> <strong>Type :</strong> {{ etablissement.type }}</p>
            <p><i class="bi bi-map-fill text-info me-1"></i> <strong>Coordonnées :</strong> {{ etablissement.latitude }}, {{ etablissement.longitude }}</p>
        </div>
    </div>
    {% else %}
        <p class="text-center text-muted">Aucun établissement trouvé.</p>
    {% endfor %}
</div>
{% endblock %}