{% extends 'front/base.html.twig' %}

{% block title %}Bienvenue - SchoolPrepar{% endblock %}

{% block body %}
<div class="text-center py-5">
    <h1 class="display-5 fw-bold" style="color:#1a3c5e;">Bienvenue sur SchoolPrepar</h1>
    <p class="lead text-muted mb-4">Veuillez choisir votre espace pour continuer :</p>

    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a href="{{ path('etablissements') }}" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-building me-2"></i>Établissements
        </a>
        <a href="{{ path('filieres') }}" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-journal-bookmark-fill me-2"></i>Filières
        </a>
        <a href="https://github.com/wilster002/shcoolprepar/tree/master" target="_blank" class="btn btn-outline-secondary btn-lg px-4">
            <i class="bi bi-github me-2"></i>Voir le dépôt GitHub
        </a>
    </div>

    <div class="row mt-5 g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 text-center h-100">
                <i class="bi bi-journal-bookmark-fill text-primary fs-1 mb-3"></i>
                <h5 class="fw-bold">Filières</h5>
                <p class="text-muted">Découvrez toutes les filières disponibles et choisissez votre orientation.</p>
                <a href="{{ path('filieres') }}" class="btn btn-outline-primary btn-sm mt-auto">Explorer</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 text-center h-100">
                <i class="bi bi-building text-success fs-1 mb-3"></i>
                <h5 class="fw-bold">Établissements</h5>
                <p class="text-muted">Consultez la liste des établissements partenaires de la plateforme.</p>
                <a href="{{ path('etablissements') }}" class="btn btn-outline-success btn-sm mt-auto">Explorer</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 text-center h-100">
                <i class="bi bi-mortarboard-fill text-warning fs-1 mb-3"></i>
                <h5 class="fw-bold">Orientation</h5>
                <p class="text-muted">Préparez votre avenir scolaire avec SchoolPrepar.</p>
                <a href="#" class="btn btn-outline-warning btn-sm mt-auto">En savoir plus</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
