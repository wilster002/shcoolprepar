<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Bienvenue - SchoolPrepar{% endblock %}</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #f5f7fa, #c3cfe2);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            text-align: center;
            background: white;
            padding: 50px 40px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            max-width: 600px;
        }

        h1 {
            color: #2c3e50;
            margin-bottom: 15px;
        }

        p {
            color: #555;
            margin-bottom: 30px;
            font-size: 16px;
        }

        .btn-group {
            display: flex;               /* boutons sur la même ligne */
            justify-content: center;     /* centrer horizontalement */
            gap: 15px;                   /* espace entre les boutons */
            flex-wrap: wrap;             /* passe à la ligne si écran trop petit */
        }

        .btn-group a {
            text-decoration: none;
        }

        .btn {
            padding: 15px 25px;
            background: #3498db;
            color: white;
            border-radius: 8px;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn:hover {
            background: #2980b9;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body>
{% block body %}
<div class="container">
    <h1>Bienvenue sur SchoolPrepar</h1>
    <p>Veuillez choisir votre espace pour continuer :</p>
    
    <div class="btn-group">
        <a href="{{ path('etablissements') }}"><span class="btn">Établissements</span></a>
        <a href="{{ path('filieres') }}"><span class="btn">Filières</span></a>
        <a href="https://github.com/wilster002/shcoolprepar/tree/master"><span class="btn">Voir le dépôt GitHub</span></a>
    </div>
</div>
{% endblock %}
</body>
</html>