<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SchoolPrepar{% endblock %}</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="{{ asset('assets/vendors/bootstrap-icons/bootstrap-icons.css') }}" rel="stylesheet">

    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f8f9fa; }
        .navbar-brand { font-weight: 800; font-size: 1.3rem; }
        .navbar { background: #1a3c5e !important; }
        .card { transition: transform 0.2s, box-shadow 0.2s; }
        .card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.12); }
        .card h3 { color: #1a3c5e; }
        footer { background: #1a3c5e; color: white; }
        footer a { color: #aad4f5; }
        .card-list { display: flex; flex-wrap: wrap; gap: 20px; }
        .card-list .card { flex: 1 1 220px; padding: 20px; background: white; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
    </style>
</head>
<body>

    {# NAVBAR #}
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="{{ path('home') }}">🎓 SchoolPrepar</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') == 'home' ? 'active fw-bold' : '' }}"
                           href="{{ path('home') }}">Accueil</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') == 'filieres' ? 'active fw-bold' : '' }}"
                           href="{{ path('user_filieres') }}">Filières</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') == 'etablissements' ? 'active fw-bold' : '' }}"
                           href="{{ path('user_etablissements') }}">Établissements</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    {# CONTENU #}
    <main class="py-4">
        <div class="container">
            {% block body %}{% endblock %}
        </div>
    </main>

    {# FOOTER #}
    <footer class="py-4 mt-4">
        <div class="container text-center">
            <p class="mb-0">&copy; {{ "now"|date("Y") }} SchoolPrepar — IT232 Développement Web II</p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>
