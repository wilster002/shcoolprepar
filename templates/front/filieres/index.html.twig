{% extends 'front/base.html.twig' %}

{% block title %}Filières - SchoolPrepar{% endblock %}

{% block body %}
<h2 class="fw-bold mb-4" style="color:#1a3c5e; border-left: 4px solid #2980b9; padding-left: 12px;">
    Liste des Filières
</h2>

<div class="card-list">
    {% for filiere in filieres %}
    <div class="card mb-3">
        <div class="card-body">
            <h3 class="card-title">{{ filiere.nom }}</h3>
            <p><i class="bi bi-journal-text text-primary me-1"></i> <strong>Description :</strong> {{ filiere.description }}</p>
            <p><i class="bi bi-mortarboard-fill text-success me-1"></i> <strong>Domaine :</strong> {{ filiere.domaine }}</p>
            <p><i class="bi bi-bar-chart-fill text-warning me-1"></i> <strong>Niveau :</strong> {{ filiere.niveau }}</p>
            <p><i class="bi bi-check-circle-fill text-info me-1"></i> <strong>Conditions d'admission :</strong> {{ filiere.conditionsAdmission }}</p>
            <p><i class="bi bi-briefcase-fill text-danger me-1"></i> <strong>Débouchés :</strong> {{ filiere.debouches }}</p>
        </div>
    </div>
    {% else %}
        <p class="text-center text-muted">Aucune filière trouvée.</p>
    {% endfor %}
</div>
{% endblock %}