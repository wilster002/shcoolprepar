{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Nom</label>
        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.nom) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Localisation</label>
        {{ form_widget(form.localisation, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.localisation) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Contact</label>
        {{ form_widget(form.contact, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.contact) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Type</label>
        {{ form_widget(form.type, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.type) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Latitude</label>
        {{ form_widget(form.latitude, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.latitude) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Longitude</label>
        {{ form_widget(form.longitude, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.longitude) }}
    </div>
</div>
<div class="d-flex gap-2 mt-2">
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-save me-1"></i> {{ button_label ?? 'Enregistrer' }}
    </button>
    <a href="{{ path('app_etablissement_index') }}" class="btn btn-outline-secondary">Annuler</a>
</div>
{{ form_end(form) }}