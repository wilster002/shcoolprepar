{% extends 'admin/base.html.twig' %}
{% block title %}Gestion des Établissements{% endblock %}

{% block body %}
<div class="page-heading">
    <div class="page-title-headings">
        <h3>Gestion des Établissements</h3>
        <a href="{{ path('app_etablissement_new') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i> Ajouter un Établissement
        </a>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-1"></i> {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<section class="section">
    <div class="card">
        <div class="card-header">
            <h4 class="card-title"><i class="bi bi-building text-success me-2"></i>Liste des Établissements</h4>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Localisation</th>
                        <th>Contact</th>
                        <th>Type</th>
                        <th>Latitude</th>
                        <th>Longitude</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for etablissement in etablissements %}
                    <tr>
                        <td><span class="badge bg-light-success text-success">{{ etablissement.id }}</span></td>
                        <td><strong>{{ etablissement.nom }}</strong></td>
                        <td class="text-muted">{{ etablissement.localisation }}</td>
                        <td>{{ etablissement.contact }}</td>
                        <td>{{ etablissement.type }}</td>
                        <td>{{ etablissement.latitude }}</td>
                        <td>{{ etablissement.longitude }}</td>
                        <td>
                            <a href="{{ path('app_etablissement_show', {'id': etablissement.id}) }}" class="btn btn-sm btn-outline-info me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('app_etablissement_edit', {'id': etablissement.id}) }}" class="btn btn-sm btn-outline-warning me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('app_etablissement_delete', {'id': etablissement.id}) }}" style="display:inline-block"
                                  onsubmit="return confirm('Confirmer la suppression ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etablissement.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i> Aucun établissement trouvé.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>
{% endblock %}
