{% extends 'admin/base.html.twig' %}
{% block title %}Gestion des Utilisateurs{% endblock %}

{% block body %}
<div class="page-heading">
    <div class="page-title-headings">
        <h3>Gestion des Utilisateurs</h3>
        <a href="{{ path('app_utilisateur_new') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-person-plus me-1"></i> Ajouter un Utilisateur
        </a>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-1"></i> {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<section class="section">
    <div class="card">
        <div class="card-header">
            <h4 class="card-title"><i class="bi bi-people-fill text-primary me-2"></i>Liste des Utilisateurs</h4>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Email</th>
                        <th>Rôle</th>
                        <th>Téléphone</th>
                        <th>Inscription</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for utilisateur in utilisateurs %}
                    <tr>
                        <td><span class="badge bg-light-primary text-primary">{{ utilisateur.id }}</span></td>
                        <td><strong>{{ utilisateur.nom }}</strong></td>
                        <td>{{ utilisateur.prenom }}</td>
                        <td>{{ utilisateur.email }}</td>
                        <td>
                            <span class="badge {{ utilisateur.role == 'admin' ? 'bg-danger' : 'bg-secondary' }}">
                                {{ utilisateur.role }}
                            </span>
                        </td>
                        <td>{{ utilisateur.telephone }}</td>
                        <td>{{ utilisateur.dateInscription ? utilisateur.dateInscription|date('d/m/Y') : '-' }}</td>
                        <td>
                            <a href="{{ path('app_utilisateur_show', {'id': utilisateur.id}) }}" class="btn btn-sm btn-outline-info me-1">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('app_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-sm btn-outline-warning me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('app_utilisateur_delete', {'id': utilisateur.id}) }}" style="display:inline-block"
                                  onsubmit="return confirm('Confirmer la suppression ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i> Aucun utilisateur trouvé.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>
{% endblock %}
