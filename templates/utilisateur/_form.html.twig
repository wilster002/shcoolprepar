{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Nom</label>
        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.nom) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Prénom</label>
        {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.prenom) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Email</label>
        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.email) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Mot de passe</label>
        {{ form_widget(form.mot_de_passe, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.mot_de_passe) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Rôle</label>
        {{ form_widget(form.role, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.role) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Téléphone</label>
        {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.telephone) }}
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Date d'inscription</label>
        {{ form_widget(form.date_inscription, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.date_inscription) }}
    </div>
</div>
<div class="d-flex gap-2 mt-2">
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-save me-1"></i> {{ button_label ?? 'Enregistrer' }}
    </button>
    <a href="{{ path('app_utilisateur_index') }}" class="btn btn-outline-secondary">Annuler</a>
</div>
{{ form_end(form) }}
